@{
    ViewData["Title"] = "Acesso Administrador — Noiva & Noivo";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>@ViewData["Title"]</title>
  
  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="~/images/Icone/casa_dourada_rabisco.svg">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Stylesheets -->
  <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true">
  <link rel="stylesheet" href="~/css/base.css" asp-append-version="true">
  <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true">
  <link rel="stylesheet" href="~/css/modal.css" asp-append-version="true"> <!-- Para Toasts -->
</head>
<body>

  <div class="login-page">
    <div class="login-page__bg"></div>
    <div class="login-page__overlay"></div>

    <div class="login-card">
      <div class="login-card__brand">
        <span class="login-card__badge">WithCode</span>
        <h1 class="login-card__title">Área Administrativa</h1>
        <p class="login-card__subtitle">Informe a senha de acesso para gerenciar a sua lista de presentes.</p>
      </div>

      <!-- Exibição de alertas vindos do servidor -->
      @if (ViewBag.Message != null)
      {
          <div class="alert alert-danger" style="margin-bottom: var(--space-md); padding: 10px; border-radius: var(--radius-md); background: rgba(201, 75, 75, 0.1); border: 1.5px solid #c94b4b; color: #c94b4b; font-size: var(--fs-xs);">
              @ViewBag.Message
          </div>
      }
      @if (TempData["Mensagem"] != null)
      {
          <div class="alert alert-success" style="margin-bottom: var(--space-md); padding: 10px; border-radius: var(--radius-md); background: rgba(44, 156, 92, 0.1); border: 1.5px solid #2c9c5c; color: #2c9c5c; font-size: var(--fs-xs);">
              @TempData["Mensagem"]
          </div>
      }
      @if (TempData["MensagemErro"] != null)
      {
          <div class="alert alert-danger" style="margin-bottom: var(--space-md); padding: 10px; border-radius: var(--radius-md); background: rgba(201, 75, 75, 0.1); border: 1.5px solid #c94b4b; color: #c94b4b; font-size: var(--fs-xs);">
              @TempData["MensagemErro"]
          </div>
      }

      <form class="login-form" id="login-form" asp-action="Index" method="post">
        @Html.AntiForgeryToken()

        <div class="login-codigo-box">
          <div class="form-group">
            <label for="login-password">Senha de Acesso</label>
            <input type="password" 
                   id="login-password" 
                   name="senha"
                   class="login-form__input" 
                   placeholder="Digite a sua senha" 
                   style="background: rgba(255, 255, 255, 0.05); border: 1.5px solid var(--color-cream-muted); border-radius: var(--radius-md); padding: 12px; color: #fff; width: 100%;"
                   required>
          </div>
        </div>

        <div style="display: flex; justify-content: center; width: 100%; margin-bottom: var(--space-lg);">
          <button type="submit" 
                  class="btn btn--primary" 
                  id="btn-submit-login" 
                  style="padding: 0.8rem 4rem; cursor: pointer; min-width: 180px; text-align: center;">
            Entrar
          </button>
        </div>

        <a href="@Url.Action("Index", "Produtos")" class="login-card__back-link" style="display: flex; align-items: center; justify-content: center; margin-top: var(--space-lg); gap: 4px; font-size: var(--fs-xs); color: var(--color-cream-muted);">
          <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" fill="none" stroke-width="2" aria-hidden="true">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          Voltar para o site
        </a>
      </form>
    </div>
  </div>

  <!-- Toast Notification -->
  <div class="toast" id="toast" role="alert" aria-live="assertive">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
    <span id="toast-msg">Código enviado com sucesso!</span>
  </div>
</body>
</html>
