@model List<CHA_CASA_NOVA_ADRIANA.Models.Produto>

@{
    ViewData["Title"] = "Catálogo Completo de Presentes — Noiva & Noivo";
    Layout = null;
    var adminLogado = Context.Session.GetString("AdminLogado") == "true";
    var cultura = System.Globalization.CultureInfo.GetCultureInfo("pt-BR");
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Catálogo Completo de Presentes — Chá de Casa Nova de Noiva & Noivo. Ajude-nos a mobiliar nossa casa escolhendo um item da lista.">
  
  <title>@ViewData["Title"]</title>

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="~/images/Icone/casa_dourada_rabisco.svg">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#d8b189">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Great+Vibes&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Stylesheets -->
  <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true">
  <link rel="stylesheet" href="~/css/base.css" asp-append-version="true">
  <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true">
  <link rel="stylesheet" href="~/css/presentes.css" asp-append-version="true">
  <link rel="stylesheet" href="~/css/modal.css" asp-append-version="true">
</head>
<body style="padding-top: var(--navbar-height);">

  <!-- ============ NAVBAR ============ -->
  <nav class="navbar navbar--scrolled" id="navbar" role="navigation" aria-label="Menu principal">
    <div class="navbar__inner">
      <a href="@Url.Action("Index", "Produtos")#inicio" class="navbar__logo" id="nav-logo" aria-label="Ir para o início">
        <div class="navbar__logo-icon">
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M3 10.5L12 3l9 7.5V20a1 1 0 01-1 1H5a1 1 0 01-1-1V10.5z"/>
            <path d="M9 21V12h6v9"/>
          </svg>
        </div>
        <div class="navbar__logo-text">
          <span class="navbar__logo-main">Chá de Casa Nova</span>
          <span class="navbar__logo-sub">Noiva & Noivo</span>
        </div>
      </a>

      <!-- Desktop Links -->
      <div class="navbar__links" role="list">
        <a href="@Url.Action("Index", "Produtos")#inicio" class="navbar__link" role="listitem">Início</a>
        <a href="@Url.Action("Presentes", "Produtos")" class="navbar__link" style="color: var(--color-gold-light);" role="listitem">Lista de Presentes</a>
        <a href="@Url.Action("Index", "Produtos")#historia" class="navbar__link" role="listitem">Sobre Nós</a>
        <a href="@Url.Action("Index", "Produtos")#como-funciona" class="navbar__link" role="listitem">Como Funciona</a>
        <a href="@Url.Action("Index", "Produtos")#recados" class="navbar__link" role="listitem">Mural de Recados</a>
      </div>

      <!-- CTA (Active/Home link) -->
      <div style="display: flex; gap: var(--space-xs); align-items: center;">
        <a href="@Url.Action("Index", "Produtos")" class="navbar__cta" style="background: transparent; border: 1.5px solid var(--color-gold-dark); color: var(--color-gold-dark);" aria-label="Voltar para a página inicial">
          <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" fill="none" stroke-width="2" aria-hidden="true">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          Voltar para a Home
        </a>
        @if (adminLogado)
        {
            <a href="@Url.Action("Admin", "Produtos")" class="navbar__cta" id="nav-admin" title="Painel Administrativo" style="background: rgba(214, 177, 137, 0.2); border: 1.5px solid var(--color-gold); color: var(--color-gold-light); padding: 8px 10px; border-radius: 50%; min-width: 34px; width: 34px; height: 34px; display: flex; align-items: center; justify-content: center;">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="margin: 0;"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            </a>
            <a href="@Url.Action("Logout", "Login")" class="navbar__cta" title="Sair" style="background: rgba(201, 75, 75, 0.1); border: 1.5px solid #c94b4b; color: #c94b4b; padding: 8px 12px; border-radius: var(--radius-full); font-size: var(--fs-xs);">
              Sair
            </a>
        }
        else
        {
            <a href="@Url.Action("Index", "Login")" class="navbar__cta" id="nav-admin" aria-label="Painel administrativo" title="Área administrativa" style="background: rgba(255, 255, 255, 0.08); border: 1.5px solid rgba(255, 255, 255, 0.15); color: var(--color-gold-light); padding: 8px 10px; border-radius: 50%; min-width: 34px; width: 34px; height: 34px; display: flex; align-items: center; justify-content: center;">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="margin: 0;"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            </a>
        }
      </div>

      <!-- Hamburger Button (Mobile) -->
      <button class="navbar__hamburger" id="hamburger" aria-label="Abrir menu" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <!-- Mobile Drawer Menu -->
    <div class="navbar__mobile-menu" id="mobile-menu" role="dialog" aria-label="Menu mobile">
      <a href="@Url.Action("Index", "Produtos")#inicio" class="navbar__mobile-link">Início</a>
      <a href="@Url.Action("Presentes", "Produtos")" class="navbar__mobile-link" style="color: var(--color-gold-light);">Presentes</a>
      <a href="@Url.Action("Index", "Produtos")#historia" class="navbar__mobile-link">Sobre Nós</a>
      <a href="@Url.Action("Index", "Produtos")#como-funciona" class="navbar__mobile-link">Como funciona</a>
      <a href="@Url.Action("Index", "Produtos")#recados" class="navbar__mobile-link">Mural de Recados</a>
      @if (adminLogado)
      {
          <a href="@Url.Action("Admin", "Produtos")" class="navbar__mobile-link" style="color: var(--color-gold-light);">Painel Admin</a>
          <a href="@Url.Action("Logout", "Login")" class="navbar__mobile-link" style="color: #c94b4b;">Sair</a>
      }
      else
      {
          <a href="@Url.Action("Index", "Login")" class="navbar__mobile-link" style="color: var(--color-gold-light);">Área Administrativa</a>
      }
      <a href="@Url.Action("Index", "Produtos")" class="navbar__mobile-cta">Voltar para a Home</a>
    </div>
  </nav>

  <!-- ============ CONTEÚDO DO CATÁLOGO ============ -->
  <main class="presentes section">
    <div class="container">
      <header class="presentes__header reveal active">
        <span class="section-label">Lista Completa</span>
        <h1 class="section-title">Catálogo de Presentes</h1>
        <p class="section-subtitle">Escolha com carinho os presentes que farão parte da história do nosso novo lar.</p>
      </header>

      <!-- Controles de busca e filtros -->
      <div class="presentes__controls reveal active">
        <!-- Caixa de Busca -->
        <div class="search-box">
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          <input type="text" id="search-input" placeholder="Buscar presente..." aria-label="Buscar presente">
        </div>

        <!-- Filtro por Categoria -->
        <div class="categorias" id="categorias" role="tablist" aria-label="Filtrar por categoria">
          <button class="categoria-btn active" data-cat="todos" role="tab" aria-selected="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z"/></svg>
            <span>Todos</span>
          </button>
          <button class="categoria-btn" data-cat="cozinha" role="tab" aria-selected="false">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2M7 2v20M21 15V2l-3 1-3-1v13"/><path d="M18 8H15M21 15a2 2 0 01-4 0"/></svg>
            <span>Cozinha</span>
          </button>
          <button class="categoria-btn" data-cat="sala" role="tab" aria-selected="false">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 9V7a2 2 0 00-2-2H6a2 2 0 00-2 2v2M4 9a2 2 0 00-2 2v4a2 2 0 002 2h16a2 2 0 002-2v-4a2 2 0 00-2-2H4zM12 14v3M8 17h8"/></svg>
            <span>Sala</span>
          </button>
          <button class="categoria-btn" data-cat="quarto" role="tab" aria-selected="false">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 4v16M2 8h18a2 2 0 012 2v9H2"/><path d="M2 14h20"/><path d="M6 14V8a2 2 0 012-2h8a2 2 0 012 2v6"/></svg>
            <span>Quarto</span>
          </button>
          <button class="categoria-btn" data-cat="eletros" role="tab" aria-selected="false">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M10 6h4M8 10h8M8 14h8M8 18h8"/></svg>
            <span>Eletros</span>
          </button>
          <button class="categoria-btn" data-cat="decoracao" role="tab" aria-selected="false">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <span>Decoração</span>
          </button>
          <button class="categoria-btn" data-cat="banheiro" role="tab" aria-selected="false">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 6l-5 5v2h14v-2L9 6zM4 13v5a2 2 0 002 2h12a2 2 0 002-2v-5"/><path d="M8 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg>
            <span>Banheiro</span>
          </button>
        </div>

        <!-- Seletor de Ordenação -->
        <select class="sort-select" id="sort-select" aria-label="Ordenar presentes por">
          <option value="default">Mais desejados</option>
          <option value="price-asc">Menor preço</option>
          <option value="price-desc">Maior preço</option>
          <option value="available">Disponíveis primeiro</option>
        </select>
      </div>

      <!-- Grade dos Presentes -->
      <div class="presentes__grid reveal active" id="presentes-grid" role="list">
        <!-- Renderizado dinamicamente pelo presentes.js a partir do presentesDb serializado -->
      </div>

      <!-- Botão Carregar Mais -->
      <div class="presentes__load-more reveal active">
        <button class="btn btn--outline-gold" id="load-more-btn">
          Carregar mais presentes
          <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" fill="none" stroke-width="2" aria-hidden="true">
            <path d="M12 5v14M5 12l7 7 7-7"/>
          </svg>
        </button>
      </div>
    </div>
  </main>

  @await Html.PartialAsync("_SiteFooter")

  <!-- ============ MODAL DE DETALHES DO PRESENTE ============ -->
  <div class="modal-overlay" id="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title">
    <div class="modal" id="modal">
      <button class="modal__close" id="modal-close" aria-label="Fechar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <div id="modal-content">
        <!-- Renderizado dinamicamente pelo presentes.js -->
      </div>
    </div>
  </div>

  <!-- Toast de Notificações -->
  <div class="toast" id="toast" role="alert" aria-live="assertive">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
    <span id="toast-msg">Sucesso!</span>
  </div>

  @Html.AntiForgeryToken()

  <!-- Configurações e Injeção do Banco de Dados Dinâmico -->
  <script>
    // Serializando o banco de dados dinâmico de produtos vindo do C# para que o JS possa gerenciar filtros/ordenadores localmente com dados reais
    window.presentesDb = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(p => new {
        id = p.Id,
        nome = p.Nome,
        categoria = p.Categoria ?? "outros",
        preco = (double)p.Valor,
        status = p.Doado ? "reservado" : "disponivel",
        progresso = p.Doado ? 100 : 0,
        quantidadeEscolhida = p.Doado ? 1 : 0,
        descricao = p.Descricao,
        textoEmocional = p.Descricao,
        imagem = p.ImagemUrl,
        destaque = false,
        desejo = false
    })));
  </script>

  <!-- Scripts -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
  <script src="~/js/main.js" asp-append-version="true"></script>
  <script src="~/js/presentes.js" asp-append-version="true"></script>
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js')
          .then(reg => console.log('Service Worker registrado!', reg))
          .catch(err => console.error('Erro ao registrar Service Worker:', err));
      });
    }
  </script>
</body>
</html>
