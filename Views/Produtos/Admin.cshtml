@model List<CHA_CASA_NOVA_ADRIANA.Models.Produto>

@{
    ViewData["Title"] = "Painel Administrativo — Vitória & Rodrigo";
    Layout = null;
    var cultura = System.Globalization.CultureInfo.GetCultureInfo("pt-BR");
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>@ViewData["Title"]</title>
  
  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="~/images/Icone/casa_dourada_rabisco.svg">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#d8b189">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Stylesheets -->
  <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true">
  <link rel="stylesheet" href="~/css/base.css" asp-append-version="true">
  <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true">
  <link rel="stylesheet" href="~/css/modal.css" asp-append-version="true">
</head>
<body style="min-height: 100vh; display: flex; flex-direction: column; background: var(--color-warm-white);">

  <!-- Navbar Administrativa -->
  <header class="admin-header">
    <div class="admin-header__inner">
      <div class="admin-header__brand">
        <span class="admin-header__badge">WithCode</span>
        <h1 class="admin-header__title">Painel Administrativo</h1>
      </div>
      <div class="admin-header__actions">
        <button id="pwa-install-btn" class="btn btn--primary" style="display: none; align-items: center; gap: 4px; padding: 0.6rem 1.2rem; cursor: pointer;">
          📲 Instalar App
        </button>
        <a href="@Url.Action("Logout", "Login")" class="btn btn--outline-gold" style="padding: 0.6rem 1.2rem;">
          Sair
        </a>
      </div>
    </div>
  </header>

  <!-- Painel Conteúdo -->
  <main class="admin-main">
    <div class="container">
      <div class="admin-title-row">
        <div>
          <span class="section-label" style="text-align: left; margin: 0;">Vitória & Rodrigo</span>
          <h2 class="admin-title">Gerenciador de Presentes</h2>
        </div>
        <a href="@Url.Action("Create", "Produtos")" class="btn btn--primary" style="display: inline-flex; align-items: center; gap: 4px;">
          <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" fill="none" stroke-width="2.5" aria-hidden="true">
            <path d="M12 5v14M5 12h14"/>
          </svg>
          Cadastrar Presente
        </a>
      </div>

      <!-- Cards de Resumo -->
      <section class="admin-stats">
        <div class="stat-card">
          <span class="stat-card__number">@ViewBag.Total</span>
          <span class="stat-card__label">Total de Itens (@ViewBag.Doados doados / @ViewBag.Disponiveis disp.)</span>
        </div>
        <div class="stat-card">
          <span class="stat-card__number">@(((decimal)ViewBag.ValorTotal).ToString("C", cultura))</span>
          <span class="stat-card__label">Valor Total do Catálogo</span>
        </div>
        <div class="stat-card">
          <span class="stat-card__number" style="color: var(--color-gold-dark);">@(((decimal)ViewBag.ValorDoados).ToString("C", cultura))</span>
          <span class="stat-card__label">Valor Recebido (Doados)</span>
        </div>
        <div class="stat-card">
          <span class="stat-card__number" style="color: #2c9c5c;">@(((decimal)ViewBag.ValorDisponivel).ToString("C", cultura))</span>
          <span class="stat-card__label">Valor Pendente (Disponíveis)</span>
        </div>
      </section>

      <!-- Tabela de Presentes -->
      <section class="admin-table-section">
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Produto</th>
                <th>Categoria</th>
                <th>Valor</th>
                <th>Status</th>
                <th>Doador</th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody>
              @if (Model == null || Model.Count == 0)
              {
                  <tr>
                    <td colspan="6" style="text-align: center; color: rgba(40,35,35,0.4); padding: 30px 0;">
                      Nenhum presente cadastrado no catálogo.
                    </td>
                  </tr>
              }
              else
              {
                  @foreach (var p in Model)
                  {
                      <tr>
                        <td style="font-weight: 600;">@p.Nome</td>
                        <td>@(p.Categoria ?? "Outros")</td>
                        <td style="font-weight: 700;">@p.Valor.ToString("C", cultura)</td>
                        <td>
                            @if (p.Doado)
                            {
                                <span class="badge badge--reserved" style="box-shadow:none;">Reservado</span>
                            }
                            else
                            {
                                <span class="badge badge--available" style="box-shadow:none;">Disponível</span>
                            }
                        </td>
                        <td>@(p.Doado ? (p.Doador ?? "Anônimo") : "-")</td>
                        <td>
                          <div class="admin-acoes">
                            <a href="@Url.Action("Edit", new { id = p.Id })" class="admin-acoes-btn admin-acoes-btn--edit">Editar</a>
                            <a href="@Url.Action("Delete", new { id = p.Id })" class="admin-acoes-btn admin-acoes-btn--delete" onclick="return confirm('Deseja realmente excluir &quot;@p.Nome&quot;?');">Excluir</a>
                          </div>
                        </td>
                      </tr>
                  }
              }
            </tbody>
          </table>
        </div>
      </section>

      <!-- Gerenciador de Recados -->
      <div class="admin-title-row" style="margin-top: var(--space-xl);">
        <div>
          <h2 class="admin-title">Gerenciador de Recados</h2>
        </div>
      </div>

      <!-- Tabela de Recados -->
      <section class="admin-table-section" style="margin-bottom: var(--space-xl);">
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Autor</th>
                <th>Mensagem</th>
                <th>Data</th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody>
              @if (ViewBag.Recados == null || ((List<CHA_CASA_NOVA_ADRIANA.Models.Recado>)ViewBag.Recados).Count == 0)
              {
                  <tr>
                    <td colspan="4" style="text-align: center; color: rgba(40,35,35,0.4); padding: 30px 0;">
                      Nenhum recado postado no mural.
                    </td>
                  </tr>
              }
              else
              {
                  @foreach (var r in (List<CHA_CASA_NOVA_ADRIANA.Models.Recado>)ViewBag.Recados)
                  {
                      <tr>
                        <td style="font-weight: 600;">@r.Nome</td>
                        <td style="max-width: 400px; white-space: normal; word-break: break-word;">@r.Mensagem</td>
                        <td>@r.DataCriacao.ToString("dd MMM yyyy HH:mm", cultura)</td>
                        <td>
                          <div class="admin-acoes">
                            <form method="POST" action="@Url.Action("ExcluirRecado", "Produtos")" onsubmit="return confirm('Deseja realmente excluir o recado de &quot;@r.Nome&quot;?');" style="display:inline;">
                              @Html.AntiForgeryToken()
                              <input type="hidden" name="id" value="@r.Id" />
                              <button type="submit" class="admin-acoes-btn admin-acoes-btn--delete">Excluir</button>
                            </form>
                          </div>
                        </td>
                      </tr>
                  }
              }
            </tbody>
          </table>
      </section>

      <!-- Histórico de Doações (Log) -->
      <div class="admin-title-row" style="margin-top: var(--space-xl);">
        <div>
          <h2 class="admin-title">Histórico de Doações (Log)</h2>
        </div>
      </div>

      <section class="admin-table-section" style="margin-bottom: var(--space-xl);">
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Data/Hora</th>
                <th>Doador</th>
                <th>Contato</th>
                <th>Presente</th>
                <th>Entrega</th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody>
              @{
                  var doacoesLog = Model!.Where(p => p.Doado).OrderByDescending(p => p.DataDoacao).ToList();
              }
              @if (doacoesLog.Count == 0)
              {
                  <tr>
                    <td colspan="6" style="text-align: center; color: rgba(40,35,35,0.4); padding: 30px 0;">
                      Nenhuma doação registrada no histórico.
                    </td>
                  </tr>
              }
              else
              {
                  @foreach (var p in doacoesLog)
                  {
                      <tr>
                        <td style="font-weight: 600;">@(p.DataDoacao?.ToString("dd MMM yyyy HH:mm", cultura) ?? "-")</td>
                        <td><strong>@(p.Doador ?? "Anônimo")</strong></td>
                        <td style="font-size: 11px; color: rgba(40,35,35,0.6);">
                          @(p.TelefoneDoador ?? "-") @(!string.IsNullOrEmpty(p.EmailDoador) ? $" / {p.EmailDoador}" : "")
                        </td>
                        <td style="font-weight: 600; color: var(--color-gold-dark);">@p.Nome</td>
                        <td>
                          <span style="font-size: 10px; font-weight: 700; text-transform: uppercase; background: rgba(214, 177, 137, 0.1); padding: 4px 8px; border-radius: var(--radius-sm); border: 1px solid rgba(214, 177, 137, 0.2);">
                            @(p.FormaEntrega ?? "Não informada")
                          </span>
                        </td>
                        <td>
                          <form method="POST" action="@Url.Action("DesfazerDoacao", "Produtos")" onsubmit="return confirm('Deseja realmente cancelar a doação deste item e devolvê-lo à lista?');" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@p.Id" />
                            <button type="submit" class="admin-acoes-btn admin-acoes-btn--delete">Liberar Item</button>
                          </form>
                        </td>
                      </tr>
                  }
              }
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </main>

  <!-- Rodapé Administrativo -->
  <footer class="admin-footer">
    <p>© 2026 Vitória & Rodrigo — Desenvolvido por WithCode</p>
  </footer>

  <!-- Toast de Notificação -->
  <div class="toast" id="toast" role="alert" aria-live="assertive">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
    <span id="toast-msg">Salvo com sucesso!</span>
  </div>

  <script>
    function showToast(msg) {
      const toast = document.getElementById('toast');
      const toastMsg = document.getElementById('toast-msg');
      if (!toast || !toastMsg) return;

      toastMsg.textContent = msg;
      toast.classList.add('show');

      setTimeout(() => {
        toast.classList.remove('show');
      }, 4000);
    }

    // Registro do Service Worker para PWA
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js')
          .then(reg => console.log('Service Worker registrado!', reg))
          .catch(err => console.error('Erro ao registrar Service Worker:', err));
      });
    }

    // Capturar o evento de instalação do PWA
    let deferredPrompt;
    const installBtn = document.getElementById('pwa-install-btn');

    window.addEventListener('beforeinstallprompt', (e) => {
      // Prevenir que o Chrome mostre o prompt automático
      e.preventDefault();
      // Guardar o evento para ser acionado depois
      deferredPrompt = e;
      // Mostrar o botão de instalação customizado na tela de Admin
      if (installBtn) {
        installBtn.style.display = 'inline-flex';
      }
    });

    if (installBtn) {
      installBtn.addEventListener('click', async () => {
        if (!deferredPrompt) return;
        // Mostrar o prompt de instalação
        deferredPrompt.prompt();
        // Aguardar a escolha do usuário
        const { outcome } = await deferredPrompt.userChoice;
        console.log(`Escolha de instalação PWA: ${outcome}`);
        // Limpar o prompt deferred, pois só pode ser usado uma vez
        deferredPrompt = null;
        // Ocultar o botão de instalação
        installBtn.style.display = 'none';
      });
    }

    window.addEventListener('appinstalled', (evt) => {
      console.log('Aplicativo instalado com sucesso!');
      if (installBtn) {
        installBtn.style.display = 'none';
      }
      showToast('Aplicativo instalado com sucesso! 🎉');
    });
  </script>
</body>
</html>