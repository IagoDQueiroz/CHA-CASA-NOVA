@model CHA_CASA_NOVA_ADRIANA.Models.Produto

@{
    ViewData["Title"] = "Obrigado";
}

<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Obrigado - Chá de Casa Nova</title>
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="icon" type="image/png" href="~/favicon.png" />
<link rel="apple-touch-icon" href="~/favicon.png" />
<link rel="stylesheet" href="~/css/site.css" />

<div class="pagina-formulario">
    <div class="form-container obrigado-container">
        <div class="topo-formulario">
            <span class="login-badge">Doação confirmada</span>
            <h1>Obrigado pelo presente</h1>
            <p>
                Sua contribuição para <strong>@Model.Nome</strong> foi registrada com sucesso.
            </p>
        </div>

        <div class="obrigado-card">
            <img src="@Model.ImagemUrl" alt="@Model.Nome" />
            <div>
                <h2>@Model.Nome</h2>
                <p>@Model.Descricao</p>
            </div>
        </div>

        <div class="acoes-formulario">
            <a asp-action="Index" class="btn-principal">Voltar para lista</a>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn-secundario">Ver detalhes</a>
        </div>
    </div>
</div>

@await Html.PartialAsync("_SiteFooter")
