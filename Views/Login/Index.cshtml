@{
    ViewData["Title"] = "Acesso Administrador";
    Layout = null;
}

<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="~/css/site.css" />

<div class="pagina-login">
    <div class="login-box">

        <div class="login-brand">
            <span class="login-badge">Chá de Casa Nova</span>
            <h1>Área Administrativa</h1>
            <p>
                Envie o código para o e-mail cadastrado e informe abaixo para gerenciar a lista.
            </p>
        </div>


        <form asp-action="Index" method="post" class="formulario-login">

            @if (ViewBag.Message != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Message
                </div>
            }

            @if (TempData["Mensagem"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Mensagem"]
                </div>
            }

            @if (TempData["MensagemErro"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["MensagemErro"]
                </div>
            }

            <div class="login-codigo-box">
                <div class="grupo-form">
                    <label for="codigo">Código de acesso</label>
                    <input type="number"
                           name="codigo"
                           id="codigo"
                           class="input-form input-codigo"
                           placeholder="0000"
                           required />
                </div>
            </div>

            <div class="acoes-login">
                <button type="submit"
                        asp-action="EnviarCodigo"
                        asp-controller="Login"
                        formnovalidate
                        class="btn-secundario">
                    Enviar código
                </button>

                <button type="submit" class="btn-principal">
                    Entrar
                </button>
            </div>

            <a asp-controller="Produtos"
               asp-action="Index"
               class="login-voltar">
                Voltar para lista
            </a>

        </form>
    </div>
</div>
