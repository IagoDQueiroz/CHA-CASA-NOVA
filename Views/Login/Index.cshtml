@{
    ViewData["Title"] = "Acesso Administrador";
    Layout = null;
}

<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="~/css/site.css" />

<div class="pagina-login">
    <div class="login-box">

        <div class="topo-formulario">
            <h1>Acesso Administrador</h1>
            <p>
                Entre com o código de acesso enviado por e-mail para administrar a lista de presentes.
            </p>
        </div>


        <form asp-action="Index" method="post" class="formulario-login">

            <div class="grupo-form">
                <label for="codigo">Código</label>
                <input type="number"
                       name="codigo"
                       id="codigo"
                       class="input-form"
                       placeholder="Digite o código recebido"
                       required />
            </div>

            <a asp-action="EnviarCodigo" asp-controller="Login">Enviar código por email</a>

            @if (ViewBag.Message != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Message
                </div>
            }

            @if (TempData["Mensagem"] != null)
            {
                <div class="alert alert-success">
                    @TempData["Mensagem"]
                </div>
            }


            <div class="acoes-formulario">
                <button type="submit" class="btn-principal">
                    Entrar
                </button>
            </div>

        </form>
    </div>
</div>