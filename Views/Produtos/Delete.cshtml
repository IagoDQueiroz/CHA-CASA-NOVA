@model CHA_CASA_NOVA_ADRIANA.Models.Produto

@{
    ViewData["Title"] = "Excluir Produto";
    var cultura = System.Globalization.CultureInfo.GetCultureInfo("pt-BR");
}

<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Excluir Produto - Chá de Casa Nova</title>
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
<link rel="icon" type="image/png" href="~/favicon.png" />
<link rel="apple-touch-icon" href="~/favicon.png" />
<link rel="stylesheet" href="~/css/site.css" />

<div class="pagina-formulario">
    <div class="form-container">

        <div class="topo-formulario">
            <h1>Excluir Produto</h1>
            <p>Tem certeza que deseja remover este item da lista?</p>
        </div>

        <div class="card-preview-delete">
            <img src="@Model.ImagemUrl" alt="@Model.Nome" class="imagem-preview-delete" />

            <div class="preview-delete-info">
                <h3>@Model.Nome</h3>
                <p>@Model.Descricao</p>
                <p><strong>Valor:</strong> @Model.Valor.ToString("C", cultura)</p>
                <p><strong>Quantidade:</strong> @Model.Quantidade</p>

                @if (Model.Doado)
                {
                    <p><strong>Status:</strong> Já doado</p>
                }
                else
                {
                    <p><strong>Status:</strong> Disponível</p>
                }

                @if (!string.IsNullOrEmpty(Model.Doador))
                {
                    <p><strong>Doador:</strong> @Model.Doador</p>
                }
            </div>
        </div>

        <form asp-action="Delete" method="post" class="acoes-formulario">
            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn-excluir">
                Confirmar Exclusão
            </button>

            <a asp-action="Index" class="btn-secundario">
                Cancelar
            </a>
        </form>

    </div>
</div>

@await Html.PartialAsync("_SiteFooter")
