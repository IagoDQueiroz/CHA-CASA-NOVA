@model List<CHA_CASA_NOVA_ADRIANA.Models.Produto>

@{
    ViewData["Title"] = "Chá de Casa Nova — Noiva & Noivo";
    Layout = null;
    var adminLogado = Context.Session.GetString("AdminLogado") == "true";
    var cultura = System.Globalization.CultureInfo.GetCultureInfo("pt-BR");
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Chá de Casa Nova — Noiva & Noivo. Participe da construção do nosso novo lar escolhendo um presente e deixando um recado especial!">
  <meta name="robots" content="index, follow">
  
  <title>@ViewData["Title"]</title>

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="~/images/Icone/casa_dourada_rabisco.svg">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#d8b189">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Great+Vibes&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Stylesheets -->
  <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true">
  <link rel="stylesheet" href="~/css/base.css" asp-append-version="true">
  <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true">
  <link rel="stylesheet" href="~/css/hero.css" asp-append-version="true">
  <link rel="stylesheet" href="~/css/sections.css" asp-append-version="true">
  <link rel="stylesheet" href="~/css/presentes.css" asp-append-version="true">
  <link rel="stylesheet" href="~/css/extra-sections.css" asp-append-version="true">
  <link rel="stylesheet" href="~/css/modal.css" asp-append-version="true">
</head>
<body>

  <!-- ============ NAVBAR ============ -->
  <nav class="navbar navbar--transparent" id="navbar" role="navigation" aria-label="Menu principal">
    <div class="navbar__inner">
      <a href="#inicio" class="navbar__logo" id="nav-logo" aria-label="Ir para o início">
        <div class="navbar__logo-icon">
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M3 10.5L12 3l9 7.5V20a1 1 0 01-1 1H5a1 1 0 01-1-1V10.5z"/>
            <path d="M9 21V12h6v9"/>
          </svg>
        </div>
        <div class="navbar__logo-text">
          <span class="navbar__logo-main">Chá de Casa Nova</span>
          <span class="navbar__logo-sub">Noiva & Noivo</span>
        </div>
      </a>

      <!-- Desktop Links -->
      <div class="navbar__links" role="list">
        <a href="#inicio" class="navbar__link" id="link-inicio" role="listitem">Início</a>
        <a href="#presentes" class="navbar__link" id="link-presentes" role="listitem">Lista de Presentes</a>
        <a href="#historia" class="navbar__link" id="link-historia" role="listitem">Sobre Nós</a>
        <a href="#como-funciona" class="navbar__link" id="link-como-funciona" role="listitem">Como Funciona</a>
        <a href="#recados" class="navbar__link" id="link-recados" role="listitem">Mural de Recados</a>
      </div>

      <!-- CTA -->
      <div style="display: flex; gap: var(--space-xs); align-items: center;">
        <a href="@Url.Action("Presentes", "Produtos")" class="navbar__cta" id="nav-cta" aria-label="Ver catálogo completo de presentes">
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 7H4a1 1 0 00-1 1v10a1 1 0 001 1h16a1 1 0 001-1V8a1 1 0 00-1-1z"/>
            <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/>
          </svg>
          Lista de Presentes
        </a>
        @if (adminLogado)
        {
            <a href="@Url.Action("Admin", "Produtos")" class="navbar__cta" id="nav-admin" title="Painel Administrativo" style="background: rgba(214, 177, 137, 0.2); border: 1.5px solid var(--color-gold); color: var(--color-gold-light); padding: 8px 10px; border-radius: 50%; min-width: 34px; width: 34px; height: 34px; display: flex; align-items: center; justify-content: center;">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="margin: 0;"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            </a>
            <a href="@Url.Action("Logout", "Login")" class="navbar__cta" title="Sair" style="background: rgba(201, 75, 75, 0.1); border: 1.5px solid #c94b4b; color: #c94b4b; padding: 8px 12px; border-radius: var(--radius-full); font-size: var(--fs-xs);">
              Sair
            </a>
        }
        else
        {
            <a href="@Url.Action("Index", "Login")" class="navbar__cta" id="nav-admin" aria-label="Painel administrativo" title="Área administrativa" style="background: rgba(255, 255, 255, 0.08); border: 1.5px solid rgba(255, 255, 255, 0.15); color: var(--color-gold-light); padding: 8px 10px; border-radius: 50%; min-width: 34px; width: 34px; height: 34px; display: flex; align-items: center; justify-content: center;">
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="margin: 0;"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            </a>
        }
      </div>

      <!-- Hamburger Button (Mobile) -->
      <button class="navbar__hamburger" id="hamburger" aria-label="Abrir menu" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <!-- Mobile Drawer Menu -->
    <div class="navbar__mobile-menu" id="mobile-menu" role="dialog" aria-label="Menu mobile">
      <a href="#inicio" class="navbar__mobile-link">Início</a>
      <a href="#presentes" class="navbar__mobile-link">Presentes</a>
      <a href="#historia" class="navbar__mobile-link">Sobre Nós</a>
      <a href="#como-funciona" class="navbar__mobile-link">Como funciona</a>
      <a href="#recados" class="navbar__mobile-link">Deixar recado</a>
      @if (adminLogado)
      {
          <a href="@Url.Action("Admin", "Produtos")" class="navbar__mobile-link" style="color: var(--color-gold-light);">Painel Admin</a>
          <a href="@Url.Action("Logout", "Login")" class="navbar__mobile-link" style="color: #c94b4b;">Sair</a>
      }
      else
      {
          <a href="@Url.Action("Index", "Login")" class="navbar__mobile-link" style="color: var(--color-gold-light);">Área Administrativa</a>
      }
      <a href="@Url.Action("Presentes", "Produtos")" class="navbar__mobile-cta">Ver todos os presentes</a>
    </div>
  </nav>

  <!-- ============ HERO (INÍCIO) ============ -->
  <section class="hero" id="inicio">
    <div class="hero__bg" aria-hidden="true">
      <picture>
        <source media="(max-width: 768px)" srcset="@Url.Content("~/images/backgrounds/Background-hero-mobile.jpg")">
        <img src="~/images/backgrounds/Background-hero.png" alt="Plano de fundo" class="hero__bg-img">
      </picture>
    </div>
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="hero__glow" aria-hidden="true"></div>
    <div class="hero__glow-2" aria-hidden="true"></div>
    <div class="hero__particles" aria-hidden="true"></div>

    <div class="hero__inner">
      <div class="hero__content reveal">
        <span class="hero__eyebrow">Seja bem-vindo</span>
        <h1 class="hero__title" id="hero-title">
          Nosso novo lar,<br>
          nossa nova <strong>história</strong>
        </h1>
        <p class="hero__subtitle" id="hero-subtitle">
          Cada detalhe foi pensado com amor, e cada presente nos aproxima ainda mais do lar que sonhamos construir juntos.
        </p>
        <div class="hero__actions">
          <a href="@Url.Action("Presentes", "Produtos")" class="btn btn--primary" id="hero-cta-presentes">
            <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" fill="none" stroke-width="2" aria-hidden="true">
              <path d="M20 7H4a1 1 0 00-1 1v10a1 1 0 001 1h16a1 1 0 001-1V8a1 1 0 00-1-1z"/>
              <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/>
            </svg>
            Escolher Presente
          </a>
          <a href="#como-funciona" class="btn btn--ghost" id="hero-cta-como">
            <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" fill="none" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 16v-4M12 8h.01"/>
            </svg>
            Como Funciona
          </a>
        </div>

        <!-- Destaques / Float cards (Model1.png) -->
        <div class="hero__highlights">
          <div class="hero__highlight-card">
            <div class="hero__highlight-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 000-7.78z"/></svg>
            </div>
            <p class="hero__highlight-text">Um Novo<br>Começo</p>
          </div>
          <div class="hero__highlight-card">
            <div class="hero__highlight-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 10.5L12 3l9 7.5V20a1 1 0 01-1 1H5a1 1 0 01-1-1V10.5z"/><path d="M9 21V12h6v9"/></svg>
            </div>
            <p class="hero__highlight-text">Um Lar<br>de Sonhos</p>
          </div>
          <div class="hero__highlight-card">
            <div class="hero__highlight-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 7H4a1 1 0 00-1 1v10a1 1 0 001 1h16a1 1 0 001-1V8a1 1 0 00-1-1z"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
            </div>
            <p class="hero__highlight-text">Sua Presença<br>Faz Melhor</p>
          </div>
        </div>
      </div>

      <!-- Assinatura do casal à direita inferior -->
      <div class="hero__signature-area reveal">
        <span class="hero__signature-text">Noiva & Noivo</span>
        <span class="hero__signature-date">27 de Junho de 2026</span>
      </div>
    </div>

    <a href="#presentes" class="hero__scroll" aria-label="Ir para baixo" aria-hidden="true">
      <span>rolar</span>
      <div class="hero__scroll-line"></div>
    </a>
  </section>

  <!-- ============ PRESENTES (SLIDER HORIZONTAL) ============ -->
  <section class="presentes section" id="presentes">
    <div class="container">
      <header class="presentes__header reveal">
        <span class="section-label">Nossa Seleção</span>
        <h2 class="section-title section-title--light" id="presentes-title">Lista de Presentes</h2>
        <p class="section-subtitle section-subtitle--light">Dê um toque de carinho no nosso lar escolhendo um dos itens destacados abaixo</p>
      </header>
    </div>

    <!-- Container do carrossel/rolagem horizontal -->
    <div class="presentes__horizontal-container">
      <!-- Botão para rolar para a eficiência -->
      <button class="presentes__scroll-btn presentes__scroll-btn--left" id="scroll-left" aria-label="Rolar para esquerda">
        <svg viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7"/></svg>
      </button>

      <!-- Trilho de rolagem contendo os cards -->
      <div class="presentes__horizontal-scroll" id="presentes-horizontal-scroll" role="list">
        <!-- Renderizado via C#/Razor para SSR rápido -->
        @foreach (var p in Model.Take(24))
        {
            <div class="presente-card card-visible" role="listitem" data-id="@p.Id">
                <div class="presente-card__image-wrap">
                    @if (!string.IsNullOrEmpty(p.ImagemUrl))
                    {
                        <img src="@p.ImagemUrl" alt="@p.Nome" loading="lazy">
                    }
                    else
                    {
                        <div class="presente-card__image-placeholder">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9l4-4 4 4 4-4 4 4"/><circle cx="8.5" cy="13.5" r="1.5"/></svg>
                        </div>
                    }
                    <div class="presente-card__status-badge">
                        @if (p.Doado)
                        {
                            <span class="badge badge--reserved">Escolhido 💛</span>
                        }
                        else
                        {
                            <span class="badge badge--available">Disponível</span>
                        }
                    </div>
                </div>
                <div class="presente-card__body">
                    <p class="presente-card__category">@p.Categoria</p>
                    <h3 class="presente-card__name">@p.Nome</h3>
                    <p class="presente-card__desc">@p.Descricao</p>
                    <div class="presente-card__footer">
                        <span class="presente-card__price">@p.Valor.ToString("C", cultura)</span>
                        @if (p.Doado)
                        {
                            <button class="presente-card__btn presente-card__btn--reserved" disabled aria-disabled="true">Reservado</button>
                        }
                        else
                        {
                            <button class="presente-card__btn">Presentear</button>
                        }
                    </div>
                </div>
            </div>
        }
      </div>

      <!-- Botão para rolar para a direita -->
      <button class="presentes__scroll-btn presentes__scroll-btn--right" id="scroll-right" aria-label="Rolar para direita">
        <svg viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
      </button>
    </div>

    <div class="presentes__load-more reveal">
      <a href="@Url.Action("Presentes", "Produtos")" class="btn btn--outline-gold" id="btn-ver-catalogo">
        Ver catálogo completo
        <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" fill="none" stroke-width="2" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ============ SOBRE NÓS ============ -->
  <section class="historia section" id="historia">
    <div class="container">
      <div class="historia__inner">
        <!-- Colagem de Polaroids reais do casal -->
        <div class="historia__photos reveal reveal--left">
          <div class="polaroid polaroid--1">
            <div class="polaroid__img-wrap">
              <img src="~/images/casal/img1.jpeg" alt="Casal">
            </div>
            <span class="polaroid__caption">Nossa história ♡</span>
          </div>
          <div class="polaroid polaroid--2">
            <div class="polaroid__img-wrap">
              <img src="~/images/casal/img2.jpeg" alt="Casal">
            </div>
            <span class="polaroid__caption">Cumplicidade</span>
          </div>
          <div class="polaroid polaroid--3">
            <div class="polaroid__img-wrap">
              <img src="~/images/casal/img3.jpeg" alt="Casal">
            </div>
            <span class="polaroid__caption">Próxima Parada: Nosso Lar</span>
          </div>
        </div>

        <!-- Texto de história do casal -->
        <div class="historia__content reveal reveal--right">
          <span class="section-label">Um pouco de nós</span>
          <h2 class="section-title" style="text-align: left; margin-bottom: var(--space-md);">O início de uma nova fase</h2>
          <blockquote class="historia__quote" id="historia-quote">
            "Mais do que uma casa física, estamos construindo o nosso porto seguro, repleto de risadas e sonhos compartilhados."
          </blockquote>

          <div class="historia__ornament">
            <div class="historia__ornament-line"></div>
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
            <div class="historia__ornament-line"></div>
          </div>

          <p class="historia__text">
            Estamos muito felizes em poder compartilhar este momento especial com as pessoas que mais amamos. Cada passo que demos até aqui foi planejado com carinho e esforço para prepararmos o nosso primeiro lar juntos.
          </p>
          <p class="historia__text">
            Se você está visitando o nosso site, você desempenha um papel fundamental em nossa trajetória. Cada item escolhido por você aqui carregará uma memória viva de carinho e amizade sempre que estivermos em nosso cotidiano.
          </p>

          <div class="historia__signature-wrap">
            <div class="historia__signature-line"></div>
            <span class="historia__signature" id="historia-signature">Noiva & Noivo</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ COMO FUNCIONA ============ -->
  <section class="como-funciona section" id="como-funciona">
    <div class="container">
      <header class="como-funciona__header reveal">
        <span class="section-label">Entenda o site</span>
        <h2 class="section-title">Como funciona</h2>
        <p class="section-subtitle">Explicamos de forma simples e cheia de carinho como participar</p>
      </header>

      <div class="como-funciona__steps reveal">
        <!-- Passo 1 -->
        <div class="step" id="step-1">
          <div class="step__icon-wrap">
            <svg class="step__icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/>
              <rect x="9" y="3" width="6" height="4" rx="1"/>
              <path d="M9 12h6M9 16h4"/>
            </svg>
            <span class="step__number">1</span>
          </div>
          <h3 class="step__title">Escolha</h3>
          <p class="step__desc">Navegue pelas categorias e escolha o item que gostaria de nos dar de presente.</p>
        </div>

        <!-- Passo 2 -->
        <div class="step" id="step-2">
          <div class="step__icon-wrap">
            <svg class="step__icon" viewBox="0 0 24 24" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <path d="M16 2v4M8 2v4M3 10h18"/>
            </svg>
            <span class="step__number">2</span>
          </div>
          <h3 class="step__title">Reserve</h3>
          <p class="step__desc">Preencha seu nome e telefone ao clicar em 'Presentear' para reservar o item na lista.</p>
        </div>

        <!-- Passo 3 -->
        <div class="step" id="step-3">
          <div class="step__icon-wrap">
            <svg class="step__icon" viewBox="0 0 24 24" aria-hidden="true">
              <rect x="1" y="3" width="15" height="13" rx="1"/>
              <path d="M16 8h5l2 5v3h-7V8z"/>
              <circle cx="5.5" cy="18.5" r="2.5"/>
              <circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
            <span class="step__number">3</span>
          </div>
          <h3 class="step__title">Entregue</h3>
          <p class="step__desc">Faça a contribuição via Pix direto no site, envie para nosso endereço ou entregue em mãos.</p>
        </div>

        <!-- Passo 4 -->
        <div class="step" id="step-4">
          <div class="step__icon-wrap">
            <svg class="step__icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 000-7.78z"/>
            </svg>
            <span class="step__number">4</span>
          </div>
          <h3 class="step__title">Agradecimento</h3>
          <p class="step__desc">Seu carinho fará parte do nosso novo lar e ficará guardado em nossa memória para sempre.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ MURAL DE RECADOS ============ -->
  <section class="recados section" id="recados">
    <div class="container">
      <header class="recados__header reveal">
        <span class="section-label">Afeto e carinho</span>
        <h2 class="section-title">Deixe um Recado</h2>
        <p class="section-subtitle">Escreva uma mensagem especial para nós celebrarmos juntos esse começo</p>
      </header>

      <div class="recados__inner">
        <!-- Formulário de Recado -->
        <div class="recados__form-wrap reveal reveal--left">
          <h3 class="recados__form-title">Mensagem de Carinho ♡</h3>
          <p class="recados__form-subtitle">Seu recado aparecerá instantaneamente no nosso mural abaixo.</p>
          <form class="recados-form" id="recados-form" method="POST" action="@Url.Action("EnviarRecado", "Produtos")">
            @Html.AntiForgeryToken()
            <div class="form-group">
              <label for="recado-nome">Seu Nome *</label>
              <input type="text" id="recado-nome" name="nome" placeholder="Como quer ser identificado?" required>
            </div>
            <div class="form-group">
              <label for="recado-msg">Mensagem *</label>
              <textarea id="recado-msg" name="mensagem" placeholder="Escreva aqui suas palavras de carinho..." required></textarea>
            </div>
            <button type="submit" class="btn btn--primary" id="btn-enviar-recado" style="width: 100%; justify-content: center;">
              Enviar Mensagem
            </button>
          </form>
        </div>

        <!-- Mural de Mensagens -->
        <div class="recados__cards reveal reveal--right" id="recados-cards" aria-live="polite">
          @if (ViewBag.Recados != null)
          {
              var recadosList = (List<CHA_CASA_NOVA_ADRIANA.Models.Recado>)ViewBag.Recados;
              if (recadosList.Count == 0)
              {
                  <div style="text-align: center; color: rgba(255,255,255,0.6); padding: 20px;">Nenhum recado ainda. Seja o primeiro! 💛</div>
              }
              else
              {
                  foreach (var r in recadosList)
                  {
                      <div class="recado-card" style="opacity: 1; transform: none; transition: none;">
                        <div class="recado-card__header">
                          <span class="recado-card__name">@r.Nome</span>
                          <span class="recado-card__date">@r.DataCriacao.ToString("dd MMM yyyy", cultura)</span>
                        </div>
                        <p class="recado-card__msg">"@r.Mensagem"</p>
                      </div>
                  }
              }
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ============ AGRADECIMENTO FINAL ============ -->
  <section class="agradecimento" id="agradecimento">
    <div class="agradecimento__bg" aria-hidden="true"></div>
    <div class="agradecimento__overlay" aria-hidden="true"></div>

    <div class="agradecimento__content">
      <div class="reveal">
        <span class="section-label">Agradecimento</span>
        <h2 class="agradecimento__title">Muito obrigado de<br><span>coração!</span></h2>
        <p class="agradecimento__text">
          Sua amizade, presença e energia positiva são os presentes mais valiosos que poderíamos receber nesta nova jornada. Cada gesto de carinho nos ajuda a moldar o lar dos nossos sonhos.
        </p>
        <span class="agradecimento__sig">Noiva & Noivo</span>

        <!-- Cards de destaque no agradecimento -->
        <div class="agradecimento__cards">
          <div class="agradecimento__card">
            <div class="agradecimento__card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
            <p class="agradecimento__card-text">Presença garantida<br>no coração 🎁</p>
          </div>
          <div class="agradecimento__card">
            <div class="agradecimento__card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 000-7.78z"/></svg>
            </div>
            <p class="agradecimento__card-text">Carinho que decora<br>nosso dia a dia</p>
          </div>
          <div class="agradecimento__card">
            <div class="agradecimento__card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 10.5L12 3l9 7.5V20a1 1 0 01-1 1H5a1 1 0 01-1-1V10.5z"/><path d="M9 21V12h6v9"/></svg>
            </div>
            <p class="agradecimento__card-text">Construção conjunta<br>deste lindo sonho</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  @await Html.PartialAsync("_SiteFooter")

  <!-- ============ MODAL DE DETALHES DO PRESENTE ============ -->
  <div class="modal-overlay" id="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title">
    <div class="modal" id="modal">
      <button class="modal__close" id="modal-close" aria-label="Fechar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <div id="modal-content">
        <!-- Renderizado dinamicamente pelo presentes.js -->
      </div>
    </div>
  </div>

  <!-- Toast de Notificações -->
  <div class="toast" id="toast" role="alert" aria-live="assertive">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
    <span id="toast-msg">Sucesso!</span>
  </div>

  @Html.AntiForgeryToken()

  <!-- Configurações e Injeção do Banco de Dados Dinâmico -->
  <script>
    // Serializando o banco de dados dinâmico de produtos vindo do C#
    window.presentesDb = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(p => new {
        id = p.Id,
        nome = p.Nome,
        categoria = p.Categoria ?? "outros",
        preco = (double)p.Valor,
        status = p.Doado ? "reservado" : "disponivel",
        progresso = p.Doado ? 100 : 0,
        quantidadeEscolhida = p.Doado ? 1 : 0,
        descricao = p.Descricao,
        textoEmocional = p.Descricao,
        imagem = p.ImagemUrl,
        destaque = false,
        desejo = false
    })));
  </script>

  <!-- Scripts -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
  <script src="~/js/main.js" asp-append-version="true"></script>
  <script src="~/js/presentes.js" asp-append-version="true"></script>
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js')
          .then(reg => console.log('Service Worker registrado!', reg))
          .catch(err => console.error('Erro ao registrar Service Worker:', err));
      });
    }
  </script>
</body>
</html>
